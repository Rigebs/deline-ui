{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "deline-core": {
      "projectType": "library",
      "root": "projects/deline-core",
      "sourceRoot": "projects/deline-core/src",
      "prefix": "dln",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/deline-core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/deline-core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "projects/deline-core/tsconfig.spec.json"
          }
        }
      }
    },
    "deline-docs": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/deline-docs",
      "sourceRoot": "projects/deline-docs/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/deline-docs/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/deline-docs/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/deline-docs/public"
              }
            ],
            "styles": [
              "projects/deline-core/src/lib/styles/_tokens.css",
              "projects/deline-docs/src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "deline-docs:build:production"
            },
            "development": {
              "buildTarget": "deline-docs:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/deline-docs/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/deline-docs/public"
              }
            ],
            "styles": [
              "projects/deline-core/src/lib/styles/_tokens.css",
              "projects/deline-docs/src/styles.css"
            ]
          }
        }
      }
    },
    "deline-icons": {
      "projectType": "library",
      "root": "projects/deline-icons",
      "sourceRoot": "projects/deline-icons/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/deline-icons/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/deline-icons/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "projects/deline-icons/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
